{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    ".next-seo-audit/types/**/*.ts",
    ".next-seo-audit/dev/types/**/*.ts",
    ".next-metadata-check/types/**/*.ts",
    ".next-metadata-check/dev/types/**/*.ts",
    ".next-metadata-debug/types/**/*.ts",
    ".next-metadata-debug/dev/types/**/*.ts",
    ".next-metadata-probe/types/**/*.ts",
    ".next-metadata-probe/dev/types/**/*.ts",
    ".next-metadata-fix/types/**/*.ts",
    ".next-metadata-fix/dev/types/**/*.ts",
    ".next-p1-analytics/types/**/*.ts",
    ".next-p1-analytics/dev/types/**/*.ts",
    ".next-p1-verify/types/**/*.ts",
    ".next-p1-verify/dev/types/**/*.ts",
    ".next-p1-structured/types/**/*.ts",
    ".next-p1-structured/dev/types/**/*.ts",
    ".next-p1-structured-webpack/types/**/*.ts",
    ".next-p1-structured-webpack/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
