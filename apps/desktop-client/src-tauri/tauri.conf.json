{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desktop-client",
  "version": "0.1.2",
  "identifier": "com.beep.desktop-client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "desktop-client",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "throne"
        ]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/beepbeep/CyberVPN/releases/download/latest/update-{{target}}-{{current_version}}.json"
      ],
      "pubkey": "dGVzdF9wdWJsaWNfa2V5X3BsYWNlaG9sZGVy"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
