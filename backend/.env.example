# CyberVPN Backend - Environment Configuration Template
# Copy this file to .env and fill in your actual values
#
# ⚠️  SECURITY WARNING - PRODUCTION DEPLOYMENT CHECKLIST
# Before deploying to production, you MUST:
# 1. Replace ALL tokens marked _REPLACE_IN_PRODUCTION with real values
# 2. Set ENVIRONMENT=production
# 3. Set SWAGGER_ENABLED=false
# 4. Set DEBUG=false
# 5. Generate cryptographic secrets using: python scripts/generate_secrets.py

# ============================================================================
# Database Configuration
# ============================================================================
# INFO-008: PRODUCTION REQUIREMENT - Database credentials
# In production, NEVER use default/development credentials.
# Use a secrets manager (e.g., AWS Secrets Manager, HashiCorp Vault, GCP Secret Manager)
# to inject DATABASE_URL at runtime. The URL should follow the format:
# postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
#
# Example secrets manager integration (Docker/K8s):
#   - Mount secret as /run/secrets/database_url
#   - Set DATABASE_URL=$(cat /run/secrets/database_url) in entrypoint
#
# Development only - replace in production:
DATABASE_URL=postgresql+asyncpg://cybervpn:cybervpn@localhost:6767/cybervpn

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=100
REDIS_POOL_WAIT_SECONDS=5

# ============================================================================
# Remnawave API Configuration
# ============================================================================
REMNAWAVE_URL=http://localhost:3000
REMNAWAVE_TOKEN=_REPLACE_IN_PRODUCTION_remnawave_token
# Dedicated webhook secret for Remnawave webhook signatures.
# This should match Remnawave's WEBHOOK_SECRET_HEADER value.
# Temporary fallback behavior uses REMNAWAVE_TOKEN if this is left empty,
# but production should set a separate value.
REMNAWAVE_WEBHOOK_SECRET=
REMNAWAVE_WEBHOOK_MAX_AGE_SECONDS=300
REMNAWAVE_WEBHOOK_FUTURE_SKEW_SECONDS=60
REMNAWAVE_DEFAULT_USER_EXPIRE_DAYS=7
REMNAWAVE_REQUEST_RETRIES=1
REMNAWAVE_RETRY_BACKOFF_SECONDS=0.25
# Optional: force new Remnawave users into a specific internal squad UUID.
# If empty, backend will try to resolve squad named REMNAWAVE_DEFAULT_INTERNAL_SQUAD_NAME,
# then fall back to the only available internal squad when exactly one exists.
REMNAWAVE_DEFAULT_INTERNAL_SQUAD_UUID=
REMNAWAVE_DEFAULT_INTERNAL_SQUAD_NAME=Default-Squad

# ============================================================================
# JWT Authentication Configuration
# ============================================================================
JWT_SECRET=_REPLACE_IN_PRODUCTION_jwt_secret_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# JWT_ISSUER=cybervpn
# JWT_AUDIENCE=cybervpn-api

# ============================================================================
# Payment Gateway Configuration
# ============================================================================
CRYPTOBOT_TOKEN=_REPLACE_IN_PRODUCTION_cryptobot_token
# `testnet` is allowed only for local/staging sandbox evidence.
# Production rejects CRYPTOBOT_NETWORK=testnet at startup.
CRYPTOBOT_NETWORK=mainnet
# Dedicated secret for HMAC-hashing customer growth codes in canonical registry
# and lifecycle tracking. If empty, backend falls back to JWT_SECRET for
# compatibility, but production should set a separate value.
GROWTH_CODE_HASH_SECRET=

# ============================================================================
# CORS Configuration
# ============================================================================
# Add every browser origin that talks to the backend directly.
# Local web apps default to:
# - client portal: http://localhost:3000
# - admin panel: http://localhost:3001
# S1 production approved browser origins:
# - https://cyber-vpn.net
# - https://admin.cyber-vpn.net
# S1 mirror domains are redirect-only and must not be API/CORS origins:
# - https://cyber-vpn.org -> https://cyber-vpn.net
# - https://admin.cyber-vpn.org -> https://admin.cyber-vpn.net
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# Application Configuration
# ============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_RELEASE=

# API server runtime
API_HOST=0.0.0.0
API_PORT=8000
UVICORN_ACCESS_LOG=false
UVICORN_SERVER_HEADER=false
UVICORN_DATE_HEADER=true
UVICORN_BACKLOG=2048
UVICORN_TIMEOUT_KEEP_ALIVE=5
UVICORN_TIMEOUT_GRACEFUL_SHUTDOWN=30
# UVICORN_LIMIT_CONCURRENCY=
# UVICORN_LIMIT_MAX_REQUESTS=

# Metrics
# ENABLE_METRICS enables FastAPI/Starlette HTTP Prometheus metrics in addition
# to the always-available process/runtime/custom business metrics endpoint.
ENABLE_METRICS=true
METRICS_HOST=0.0.0.0
METRICS_PORT=9092
# Shared secret used by trusted Next.js app routes to forward frontend runtime
# observability events into the backend metrics/log pipeline.
FRONTEND_OBSERVABILITY_INTERNAL_SECRET=

# ============================================================================
# Rate Limiting Configuration
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
HELIX_ADMIN_READ_RATE_LIMIT_REQUESTS=1500
RATE_LIMIT_AUTH_SENSITIVE_REQUESTS=20
RATE_LIMIT_PAYMENT_WRITE_REQUESTS=30
RATE_LIMIT_TRIAL_ACTIVATE_REQUESTS=10
STAGE1_TRIAL_PROVISIONING_ENABLED=false
STAGE1_PAID_PROVISIONING_ENABLED=false
RATE_LIMIT_GROWTH_SENSITIVE_REQUESTS=60
RATE_LIMIT_SUPPORT_WRITE_REQUESTS=30
TRUST_PROXY_HEADERS=false

# ============================================================================
# OTP Configuration
# ============================================================================
OTP_EXPIRATION_HOURS=3
OTP_MAX_ATTEMPTS=5
OTP_MAX_RESENDS=3
OTP_RESEND_WINDOW_HOURS=1
OTP_RESEND_COOLDOWN_SECONDS=30

# ============================================================================
# OAuth Configuration (Optional)
# ============================================================================
# S2 public OAuth rollout: only Google and GitHub are allowed.
# Leave empty in production until the selected providers have real credentials.
# If google/github are enabled in production, startup fails without the matching
# client ID/secret pair and OAUTH_WEB_BASE_URL.
# OAUTH_ENABLED_LOGIN_PROVIDERS=
# OAUTH_TRUSTED_EMAIL_LINK_PROVIDERS=google,github
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=
# TELEGRAM_BOT_INTERNAL_SECRET=
# TELEGRAM_OIDC_CLIENT_ID=
# TELEGRAM_OIDC_CLIENT_SECRET=
# TELEGRAM_OIDC_ISSUER=https://oauth.telegram.org
# TELEGRAM_OIDC_DISCOVERY_URL=https://oauth.telegram.org/.well-known/openid-configuration
# TELEGRAM_OIDC_JWKS_URL=https://oauth.telegram.org/.well-known/jwks.json
# TELEGRAM_OIDC_ALLOWED_AUDIENCE=
# TELEGRAM_OIDC_CLOCK_SKEW_SECONDS=60
# OAUTH_WEB_BASE_URL=http://localhost:3000
# OAUTH_ALLOWED_REDIRECT_URIS=cybervpn://oauth/callback
# OAUTH_RETAINED_ACCESS_TOKEN_PROVIDERS=
# OAUTH_RETAINED_REFRESH_TOKEN_PROVIDERS=
# OAUTH_TOKEN_PLAINTEXT_FALLBACK_ENABLED=true

# ============================================================================
# SECURITY SETTINGS (from Security Remediation v1.0)
# ============================================================================

# Registration Security (CRIT-1) - Disabled by default
REGISTRATION_ENABLED=false
REGISTRATION_INVITE_REQUIRED=true
INVITE_TOKEN_EXPIRY_HOURS=24

# Debug Mode - MUST be false in production
DEBUG=false

# Rate Limit Fail Behavior (MED-1)
# false = fail-closed (reject requests on Redis error) - PRODUCTION
# true = fail-open (allow requests on Redis error) - DEVELOPMENT ONLY
RATE_LIMIT_FAIL_OPEN=false

# Mobile Rate Limit Fail Behavior (MED-4)
MOBILE_RATE_LIMIT_FAIL_OPEN=false

# JWT Algorithm Allowlist (MED-5)
JWT_ALLOWED_ALGORITHMS=HS256,HS384,HS512

# Swagger UI (MED-7) - Disabled by default for security
# Set to true only in development if needed
SWAGGER_ENABLED=false

# TOTP Encryption Key (HIGH-001) - REQUIRED IN PRODUCTION
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# TOTP_ENCRYPTION_KEY=your-secure-key-here

# Admin 2FA enforcement - MUST be true in production.
ADMIN_2FA_REQUIRED=false

# Partner platform staged rollout flags - keep disabled until the matching S3 gate is passed.
PARTNER_PORTAL_ENABLED=false
PARTNER_APPLICATIONS_ENABLED=false
PARTNER_CODES_ENABLED=false
PARTNER_ATTRIBUTION_ENABLED=false
PARTNER_STOREFRONTS_ENABLED=false
PARTNER_REPORTING_ENABLED=false
PARTNER_SETTLEMENT_SANDBOX_ENABLED=false
PARTNER_WEBHOOKS_ENABLED=false
PARTNER_PAYOUTS_ENABLED=false
PARTNER_EVENT_BACKBONE_ENABLED=false

# OAuth Token Encryption Key (OAuth P2) - REQUIRED IN PRODUCTION
# Prefer a dedicated key over TOTP_ENCRYPTION_KEY for provider access/refresh tokens.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# OAUTH_TOKEN_ENCRYPTION_KEY=your-secure-key-here

# Trusted Proxy IPs (MED-8) - Set if behind reverse proxy
# TRUSTED_PROXY_IPS=10.0.0.1,10.0.0.2
# TRUST_PROXY_HEADERS=true

# Token Device Binding (MED-2) - Strict fingerprint validation
ENFORCE_TOKEN_BINDING=false

# Log Sanitization (LOW-4)
LOG_SANITIZATION_ENABLED=true

# ============================================================================
# PRODUCTION CHECKLIST
# ============================================================================
# Before deploying to production, verify:
# [ ] ENVIRONMENT=production
# [ ] DEBUG=false
# [ ] SWAGGER_ENABLED=false
# [ ] TOTP_ENCRYPTION_KEY is set (unique per environment)
# [ ] OAUTH_TOKEN_ENCRYPTION_KEY is set or documented fallback is accepted
# [ ] JWT_SECRET is a unique cryptographic random value
# [ ] RATE_LIMIT_FAIL_OPEN=false
# [ ] MOBILE_RATE_LIMIT_FAIL_OPEN=false
# [ ] OAUTH_ENABLED_LOGIN_PROVIDERS matches the rollout plan
# [ ] OAUTH_TRUSTED_EMAIL_LINK_PROVIDERS matches verified-trust policy
# [ ] OAUTH_RETAINED_ACCESS_TOKEN_PROVIDERS is empty unless a reviewed feature requires provider access tokens
# [ ] OAUTH_RETAINED_REFRESH_TOKEN_PROVIDERS is empty unless a reviewed feature requires refresh tokens
# [ ] OAUTH_WEB_BASE_URL exactly matches the public frontend origin
# [ ] CORS_ORIGINS is limited to https://cyber-vpn.net and https://admin.cyber-vpn.net in S1 production
# [ ] COOKIE_SECURE=true in production
# [ ] COOKIE_DOMAIN is empty for host-only cookies or cyber-vpn.net if subdomain sharing is intentionally required
# [ ] CSRF_PROTECTION_ENABLED=true in production
# [ ] ADMIN_HOST_PROTECTION_ENABLED=true in production
# [ ] ADMIN_ALLOWED_HOSTS=admin.cyber-vpn.net in production; admin.cyber-vpn.org is redirect-only
# [ ] ADMIN_2FA_REQUIRED=true in production
# [ ] S1 route-category rate limits are set for auth/payment/trial/growth/support
# [ ] TRUSTED_PROXY_IPS configured if behind load balancer
# [ ] API_HOST / API_PORT / METRICS_HOST / METRICS_PORT match the deployment topology
# [ ] UVICORN_* runtime limits match the ingress/load-balancer behaviour
# [ ] All tokens/secrets are production values (not development)
