{
  "name": "vpn-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare:i18n": "node ./scripts/generate-message-bundles.mjs",
    "prepare:workspace": "bash ./scripts/ensure-local-next-deps.sh",
    "predev": "npm run prepare:workspace && npm run prepare:i18n",
    "dev": "node ./scripts/dev-server.mjs",
    "prebuild": "npm run prepare:workspace && npm run prepare:i18n",
    "build": "next build",
    "start": "next start",
    "start:prod-like": "bash ./scripts/start-prod-like.sh",
    "prelint": "npm run prepare:i18n",
    "lint": "eslint",
    "pretest": "npm run prepare:i18n",
    "test": "vitest",
    "pretest:run": "npm run prepare:i18n",
    "test:run": "vitest run",
    "pretest:mobile-layout": "npm run prepare:i18n",
    "test:mobile-layout": "vitest run src/__tests__/mobile-layout-regressions.test.tsx",
    "pretest:coverage": "npm run prepare:i18n",
    "test:coverage": "vitest run --coverage",
    "check:seo": "node scripts/seo-static-audit.mjs",
    "check:mobile-performance": "node scripts/mobile-performance-budget.mjs",
    "check:mobile": "npm run test:mobile-layout && npm run check:mobile-performance",
    "generate:api-types": "node scripts/generate-api-types.mjs"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@sentry/nextjs": "^10.47.0",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-table": "^8.21.3",
    "@twa-dev/sdk": "^8.0.2",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.15.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.15",
    "html-to-image": "^1.11.13",
    "input-otp": "^1.4.2",
    "lenis": "^1.3.21",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.563.0",
    "motion": "^12.38.0",
    "next": "^16.2.3",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.8",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-qr-code": "^2.0.18",
    "schema-dts": "^1.1.5",
    "tailwind-merge": "^3.5.0",
    "three": "^0.174.0",
    "web-vitals": "^5.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.3",
    "happy-dom": "^20.9.0",
    "jsdom": "^28.1.0",
    "msw": "^2.12.14",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "follow-redirects": "^1.16.0"
  }
}
