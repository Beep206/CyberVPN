### APP ###
APP_PORT=3000
METRICS_PORT=3001

### DATABASE ###
POSTGRES_USER=postgres
POSTGRES_PASSWORD=local_dev_postgres
POSTGRES_DB=postgres
DATABASE_URL=postgresql://postgres:local_dev_postgres@remnawave-db:5432/postgres

### REDIS / VALKEY ###
REDIS_HOST=remnawave-redis
REDIS_PORT=6379

### JWT ###
JWT_AUTH_SECRET=change-me-local-only
JWT_API_TOKENS_SECRET=change-me-local-only

### FRONT_END / SUBSCRIPTION ###
FRONT_END_DOMAIN=panel.localhost
PANEL_DOMAIN=panel.localhost
SUB_PUBLIC_DOMAIN=sub.localhost

### METRICS (Basic Auth) ###
METRICS_USER=admin
METRICS_PASS=metrics_local_password

### TELEGRAM NOTIFICATIONS (optional) ###
IS_TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_API_ROOT=https://api.telegram.org
TELEGRAM_BOT_PROXY=
# Format: chat_id or chat_id:thread_id for forum topics
TELEGRAM_NOTIFY_USERS=
TELEGRAM_NOTIFY_NODES=
TELEGRAM_NOTIFY_CRM=
TELEGRAM_NOTIFY_SERVICE=
TELEGRAM_NOTIFY_TBLOCKER=
# Optional scheduler-backed notification families
BANDWIDTH_USAGE_NOTIFICATIONS_ENABLED=false
BANDWIDTH_USAGE_NOTIFICATIONS_THRESHOLD=[80,90]
NOT_CONNECTED_USERS_NOTIFICATIONS_ENABLED=false
NOT_CONNECTED_USERS_NOTIFICATIONS_AFTER_HOURS=[24,72]

### GRAFANA ###
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=grafana_local_password

### ALERTMANAGER / STAGE 1 ALERT DELIVERY ###
# Local defaults validate configuration only. Set ALERTMANAGER_REQUIRE_LIVE_RECEIVERS=true
# in staging/production and replace token/SMTP placeholders before accepting go-live evidence.
ALERTMANAGER_REQUIRE_LIVE_RECEIVERS=false
ALERTMANAGER_TELEGRAM_BOT_TOKEN=000000000:stage1-local-placeholder
ALERTMANAGER_TELEGRAM_CHAT_ID=-5173727789
ALERTMANAGER_BACKUP_EMAIL=backup@cyber-vpn.net
ALERTMANAGER_SMTP_FROM=alerts@cyber-vpn.net
ALERTMANAGER_SMTP_SMARTHOST=mailpit-1:1025
ALERTMANAGER_SMTP_HELLO=cyber-vpn.net
ALERTMANAGER_SMTP_AUTH_USERNAME=
ALERTMANAGER_SMTP_PASSWORD=
ALERTMANAGER_SMTP_REQUIRE_TLS=false

### HELIX ###
HELIX_ENABLED=false
HELIX_ADAPTER_PORT=8088
HELIX_NODE_PORT=8091
HELIX_NODE_2_PORT=8092
HELIX_REMNAWAVE_TOKEN=
HELIX_INTERNAL_AUTH_TOKEN=replace-me-too
HELIX_MANIFEST_SIGNING_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
HELIX_MANIFEST_SIGNING_KEY_ID=sig-key-local-dev
HELIX_MANIFEST_TTL_SECONDS=3600
HELIX_DEFAULT_ROLLOUT_CHANNEL=lab
HELIX_DATABASE_MAX_CONNECTIONS=10
HELIX_DATABASE_ACQUIRE_TIMEOUT_SECONDS=5
HELIX_METRICS_PREFIX=helix
HELIX_NODE_METRICS_PREFIX=helix_node
HELIX_LAB_NODE_ID=node-lab-01
HELIX_LAB_NODE_2_ID=node-lab-02
HELIX_LAB_DATA_PORT=9443
HELIX_LAB_NODE_2_DATA_PORT=9444
HELIX_LAB_INSTANCE_ID=
HELIX_LAB_INSTANCE_ID_2=
HELIX_NODE_DAEMON_VERSION=v0.1.0
HELIX_ASSIGNMENT_POLL_INTERVAL_SECONDS=15
HELIX_HEALTH_GATE_TIMEOUT_SECONDS=15
HELIX_LOG_LEVEL=info
