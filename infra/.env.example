### APP ###
APP_PORT=3000
METRICS_PORT=3001

### DATABASE ###
POSTGRES_USER=postgres
POSTGRES_PASSWORD=local_dev_postgres
POSTGRES_DB=postgres
DATABASE_URL=postgresql://postgres:local_dev_postgres@remnawave-db:5432/postgres

### REDIS / VALKEY ###
REDIS_HOST=remnawave-redis
REDIS_PORT=6379

### JWT ###
JWT_AUTH_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
JWT_API_TOKENS_SECRET=fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210

### FRONT_END / SUBSCRIPTION ###
FRONT_END_DOMAIN=panel.localhost
SUB_PUBLIC_DOMAIN=sub.localhost

### METRICS (Basic Auth) ###
METRICS_USER=admin
METRICS_PASS=metrics_local_password

### TELEGRAM NOTIFICATIONS (optional) ###
IS_TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFY_USERS_CHAT_ID=

### GRAFANA ###
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=grafana_local_password

### HELIX ###
HELIX_ENABLED=false
HELIX_ADAPTER_PORT=8088
HELIX_NODE_PORT=8091
HELIX_NODE_2_PORT=8092
HELIX_REMNAWAVE_TOKEN=
HELIX_INTERNAL_AUTH_TOKEN=replace-me-too
HELIX_MANIFEST_SIGNING_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
HELIX_MANIFEST_SIGNING_KEY_ID=sig-key-local-dev
HELIX_MANIFEST_TTL_SECONDS=3600
HELIX_DEFAULT_ROLLOUT_CHANNEL=lab
HELIX_DATABASE_MAX_CONNECTIONS=10
HELIX_DATABASE_ACQUIRE_TIMEOUT_SECONDS=5
HELIX_METRICS_PREFIX=helix
HELIX_NODE_METRICS_PREFIX=helix_node
HELIX_LAB_NODE_ID=node-lab-01
HELIX_LAB_NODE_2_ID=node-lab-02
HELIX_LAB_DATA_PORT=9443
HELIX_LAB_NODE_2_DATA_PORT=9444
HELIX_LAB_INSTANCE_ID=
HELIX_LAB_INSTANCE_ID_2=
HELIX_NODE_DAEMON_VERSION=v0.1.0
HELIX_ASSIGNMENT_POLL_INTERVAL_SECONDS=15
HELIX_HEALTH_GATE_TIMEOUT_SECONDS=15
HELIX_LOG_LEVEL=info
