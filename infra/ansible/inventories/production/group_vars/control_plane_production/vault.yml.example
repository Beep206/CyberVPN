vault_control_plane_helix_adapter_remnawave_token: "replace-with-helix-adapter-remnawave-token"
vault_control_plane_manifest_signing_key: "replace-with-helix-manifest-signing-key"

vault_control_plane_remnawave_env_extra: {}
