# Stage 1 uses the standard Next.js Node server path for admin/frontend images.
# The image is intentionally workspace-scoped so the deployment can build a
# single Next.js app without requiring a full monorepo runtime install.
FROM node:24-alpine

ARG NEXT_WORKSPACE=admin
ARG NEXT_PUBLIC_SITE_URL=https://admin.cyber-vpn.net
ARG NEXT_PUBLIC_API_URL=https://cyber-vpn.net
ARG NEXT_PUBLIC_STAGE1_ADDONS_ENABLED=false
ARG NEXT_PUBLIC_STAGE1_GROWTH_EVIDENCE_APPROVED=true
ARG NEXT_PUBLIC_STAGE1_REFERRAL_ENABLED=true
ARG NEXT_PUBLIC_STAGE1_PROMO_CODES_ENABLED=true
ARG NEXT_PUBLIC_STAGE1_GIFT_CODES_ENABLED=true
ARG NEXT_PUBLIC_STAGE1_CHECKOUT_CODES_ENABLED=true
ARG NEXT_PUBLIC_PARTNER_PORTAL_ENABLED=true
ARG NEXT_PUBLIC_PARTNER_STOREFRONTS_ENABLED=true
ARG NEXT_PUBLIC_PARTNER_PILOT_ENABLED=true
ARG NEXT_PUBLIC_PARTNER_PORTAL_HOST=partner.cyber-vpn.net
ARG NEXT_PUBLIC_PARTNER_PORTAL_HOSTS=partner.cyber-vpn.net
ARG NEXT_PUBLIC_PARTNER_STOREFRONT_HOSTS=storefront.cyber-vpn.net
ARG NEXT_PUBLIC_PARTNER_API_AUTH_REALM=partner
ARG NEXT_PUBLIC_PARTNER_PORTAL_SIMULATION_ENABLED=false
ARG API_INTERNAL_ORIGIN=http://cybervpn-backend:8000

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV NEXT_PUBLIC_SITE_URL=${NEXT_PUBLIC_SITE_URL}
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_STAGE1_ADDONS_ENABLED=${NEXT_PUBLIC_STAGE1_ADDONS_ENABLED}
ENV NEXT_PUBLIC_STAGE1_GROWTH_EVIDENCE_APPROVED=${NEXT_PUBLIC_STAGE1_GROWTH_EVIDENCE_APPROVED}
ENV NEXT_PUBLIC_STAGE1_REFERRAL_ENABLED=${NEXT_PUBLIC_STAGE1_REFERRAL_ENABLED}
ENV NEXT_PUBLIC_STAGE1_PROMO_CODES_ENABLED=${NEXT_PUBLIC_STAGE1_PROMO_CODES_ENABLED}
ENV NEXT_PUBLIC_STAGE1_GIFT_CODES_ENABLED=${NEXT_PUBLIC_STAGE1_GIFT_CODES_ENABLED}
ENV NEXT_PUBLIC_STAGE1_CHECKOUT_CODES_ENABLED=${NEXT_PUBLIC_STAGE1_CHECKOUT_CODES_ENABLED}
ENV NEXT_PUBLIC_PARTNER_PORTAL_ENABLED=${NEXT_PUBLIC_PARTNER_PORTAL_ENABLED}
ENV NEXT_PUBLIC_PARTNER_STOREFRONTS_ENABLED=${NEXT_PUBLIC_PARTNER_STOREFRONTS_ENABLED}
ENV NEXT_PUBLIC_PARTNER_PILOT_ENABLED=${NEXT_PUBLIC_PARTNER_PILOT_ENABLED}
ENV NEXT_PUBLIC_PARTNER_PORTAL_HOST=${NEXT_PUBLIC_PARTNER_PORTAL_HOST}
ENV NEXT_PUBLIC_PARTNER_PORTAL_HOSTS=${NEXT_PUBLIC_PARTNER_PORTAL_HOSTS}
ENV NEXT_PUBLIC_PARTNER_STOREFRONT_HOSTS=${NEXT_PUBLIC_PARTNER_STOREFRONT_HOSTS}
ENV NEXT_PUBLIC_PARTNER_API_AUTH_REALM=${NEXT_PUBLIC_PARTNER_API_AUTH_REALM}
ENV NEXT_PUBLIC_PARTNER_PORTAL_SIMULATION_ENABLED=${NEXT_PUBLIC_PARTNER_PORTAL_SIMULATION_ENABLED}
ENV API_INTERNAL_ORIGIN=${API_INTERNAL_ORIGIN}
ENV API_URL=${API_INTERNAL_ORIGIN}

WORKDIR /app

RUN apk add --no-cache bash

COPY ${NEXT_WORKSPACE}/package.json ${NEXT_WORKSPACE}/package-lock.json ./
RUN npm ci --include=dev --no-fund --no-audit

COPY ${NEXT_WORKSPACE}/ ./
RUN npm run build
RUN npm prune --omit=dev --no-fund --no-audit
RUN chown -R node:node /app/.next

USER node

EXPOSE 3000

CMD ["npm", "run", "start"]
