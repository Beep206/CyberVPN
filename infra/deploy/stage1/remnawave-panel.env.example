APP_PORT=3000
METRICS_PORT=3001
API_INSTANCES=1

POSTGRES_USER=remnawave
POSTGRES_PASSWORD=replace-with-production-secret
POSTGRES_DB=remnawave
DATABASE_URL=postgresql://remnawave:replace-with-production-secret@cybervpn-remnawave-postgres:5432/remnawave

REDIS_HOST=cybervpn-remnawave-valkey
REDIS_PORT=6379

JWT_AUTH_SECRET=TODO_SET_RUNTIME_VALUE
JWT_API_TOKENS_SECRET=TODO_SET_RUNTIME_VALUE

PANEL_DOMAIN=remnawave.internal.cyber-vpn.net
FRONT_END_DOMAIN=*
SUB_PUBLIC_DOMAIN=api.cyber-vpn.net/api/sub

SWAGGER_PATH=/docs
SCALAR_PATH=/scalar
IS_DOCS_ENABLED=false

METRICS_USER=admin
METRICS_PASS=replace-with-production-secret

WEBHOOK_ENABLED=false
WEBHOOK_URL=https://api.cyber-vpn.net/api/v1/webhooks/remnawave
WEBHOOK_SECRET_HEADER=TODO_SET_RUNTIME_VALUE

IS_TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=replace-with-telegram-token-if-enabled
TELEGRAM_NOTIFY_USERS=replace-with-chat-id-if-enabled
TELEGRAM_NOTIFY_NODES=replace-with-chat-id-if-enabled
TELEGRAM_NOTIFY_CRM=replace-with-chat-id-if-enabled
TELEGRAM_NOTIFY_SERVICE=replace-with-chat-id-if-enabled
TELEGRAM_NOTIFY_TBLOCKER=replace-with-chat-id-if-enabled
