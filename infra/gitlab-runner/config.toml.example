concurrent = 2
check_interval = 0
shutdown_timeout = 0

[session_server]
  session_timeout = 1800

[[runners]]
  name = "cybervpn-h-docker-protected"
  url = "https://gitlab.h.cyber-vpn.net"
  token = "REDACTED"
  executor = "docker"
  limit = 2
  request_concurrency = 1
  output_limit = 8192
  cache_dir = "/cache"
  debug_trace_disabled = true
  [runners.cache]
    Type = "filesystem"
    Shared = true
  [runners.docker]
    tls_verify = false
    image = "ubuntu:24.04"
    memory = "8g"
    memory_swap = "12g"
    memory_reservation = "2g"
    cpus = "8"
    privileged = false
    disable_entrypoint_overwrite = false
    oom_kill_disable = false
    disable_cache = false
    volumes = ["/srv/storage/gitlab-cache:/cache:rw"]
    allowed_images = ["alpine:*", "ubuntu:*", "node:*", "python:*", "docker:*", "docker.io/library/*:*", "ghcr.io/beep206/cybervpn/*:*", "registry.h.cyber-vpn.net/root/*:*"]
    pull_policy = ["if-not-present"]
    shm_size = 0

[[runners]]
  name = "cybervpn-h-dind-protected"
  url = "https://gitlab.h.cyber-vpn.net"
  token = "REDACTED"
  executor = "docker"
  limit = 1
  tag_list = ["dind"]
  run_untagged = false
  locked = true
  [runners.cache]
    Type = "filesystem"
    Shared = false
  [runners.docker]
    tls_verify = false
    image = "docker:27-cli"
    privileged = true
    disable_entrypoint_overwrite = false
    oom_kill_disable = false
    disable_cache = false
    volumes = ["/cache"]
    shm_size = 0
