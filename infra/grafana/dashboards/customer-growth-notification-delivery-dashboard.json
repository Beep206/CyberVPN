      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "Repair And Escalation Trends",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(customer_growth:notification_customer_recovery_requests:increase24h{surface=~\"$surface\",delivery_channel=~\"$delivery_channel\"})",
          "legendFormat": "customer_recovery_requests",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(customer_growth:notification_support_escalations:increase24h{surface=~\"$surface\",delivery_channel=~\"$delivery_channel\"})",
          "legendFormat": "support_escalations",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(customer_growth:notification_repairs_completed:increase24h{surface=~\"$surface\",delivery_channel=~\"$delivery_channel\"})",
          "legendFormat": "repairs_completed",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(customer_growth:notification_support_resolutions:increase24h{surface=~\"$surface\",delivery_channel=~\"$delivery_channel\"})",
          "legendFormat": "support_resolved",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(customer_growth:notification_deliveries_recovered:increase24h{surface=~\"$surface\",delivery_channel=~\"$delivery_channel\"})",
          "legendFormat": "deliveries_recovered",
          "refId": "E"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "id": 7,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "Unresolved Backlog By Channel",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (delivery_channel) (customer_growth:notification_unresolved_backlog_delta:24h{surface=~\"$surface\",delivery_channel=~\"$delivery_channel\"})",
          "legendFormat": "{{delivery_channel}}",
          "refId": "A"
        }
      ]
