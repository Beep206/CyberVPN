      "pluginVersion": "11.5.2",
      "targets": [
        {
          "refId": "A",
          "expr": "max_over_time(remnawave_process_event_loop_p99_ms{job=\"remnawave\",instance_name=\"api\"}[30d]) or vector(0)",
