    {
      "id": 4,
      "type": "stat",
      "title": "Heap Headroom (30d)",
      "description": "Remaining headroom before the API process reaches 100% heap usage.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 6
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "refId": "A",
          "expr": "100 - max_over_time((100 * remnawave_process_heap_used_bytes{job=\"remnawave\",instance_name=\"api\"} / clamp_min(remnawave_process_heap_total_bytes{job=\"remnawave\",instance_name=\"api\"}, 1))[30d:])",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "green",
                "value": 15
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
