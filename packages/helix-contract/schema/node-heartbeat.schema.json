{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cybervpn.dev/helix/schema/node-heartbeat.schema.json",
  "title": "Helix Node Heartbeat",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "heartbeat_id",
    "node_id",
    "rollout_id",
    "observed_at",
    "transport_profile",
    "daemon",
    "bundle",
    "health",
    "counters",
    "capabilities"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "heartbeat_id": {
      "type": "string",
      "format": "uuid"
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "rollout_id": {
      "type": "string",
      "pattern": "^rollout-[a-z0-9-]+$"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "transport_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transport_profile_id",
        "profile_family",
        "profile_version",
        "policy_version"
      ],
      "properties": {
        "transport_profile_id": {
          "type": "string",
          "pattern": "^ptp-[a-z0-9-]+$"
        },
        "profile_family": {
          "type": "string",
          "minLength": 1
        },
        "profile_version": {
          "type": "integer",
          "minimum": 1
        },
        "policy_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "daemon": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "instance_id",
        "status"
      ],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^v?[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "instance_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "ready",
            "degraded",
            "rollback",
            "starting"
          ]
        }
      }
    },
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_version",
        "last_known_good_version"
      ],
      "properties": {
        "active_version": {
          "type": "string",
          "minLength": 1
        },
        "pending_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "last_known_good_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ready",
        "runtime_healthy",
        "apply_state",
        "latency_ms"
      ],
      "properties": {
        "ready": {
          "type": "boolean"
        },
        "runtime_healthy": {
          "type": "boolean"
        },
        "apply_state": {
          "type": "string",
          "enum": [
            "idle",
            "applying",
            "failed",
            "rolled-back"
          ]
        },
        "latency_ms": {
          "type": "integer",
          "minimum": 0
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "counters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rollback_total",
        "apply_fail_total"
      ],
      "properties": {
        "rollback_total": {
          "type": "integer",
          "minimum": 0
        },
        "apply_fail_total": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "capabilities": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
