ADAPTER_BIND_ADDR=127.0.0.1:8088
ENVIRONMENT=development
REMNAWAVE_URL=http://localhost:3005
REMNAWAVE_TOKEN=replace-me
DATABASE_URL=postgresql://cybervpn:cybervpn@localhost:6767/cybervpn
DATABASE_MAX_CONNECTIONS=10
DATABASE_ACQUIRE_TIMEOUT_SECONDS=5
METRICS_PREFIX=helix
INTERNAL_AUTH_TOKEN=replace-me-too
MANIFEST_SIGNING_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
MANIFEST_SIGNING_KEY_ID=sig-key-local-dev
MANIFEST_TTL_SECONDS=3600
DEFAULT_ROLLOUT_CHANNEL=lab
SENTRY_DSN=
SENTRY_RELEASE=helix-adapter@0.1.0+local
SENTRY_TRACES_SAMPLE_RATE=0.0
HELIX_ADAPTER_OBSERVABILITY_INTERNAL_SECRET=
HELIX_ADAPTER_SMOKE_MODE=false
LOG_LEVEL=info
