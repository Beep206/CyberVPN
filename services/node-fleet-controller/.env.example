SERVICE_NAME=cybervpn-node-fleet-controller
ENVIRONMENT=development
LOG_LEVEL=INFO

SENTRY_DSN=
SENTRY_RELEASE=
FLEET_CONTROLLER_OBSERVABILITY_INTERNAL_SECRET=

API_HOST=0.0.0.0
API_PORT=8085

DATABASE_URL=sqlite+aiosqlite:///./node_fleet_controller.db
DATABASE_ECHO=false

NATS_URL=nats://localhost:4222
NATS_STREAM_NAME=NODE_LIFECYCLE_EVENTS
NATS_PUBLISH_ENABLED=false
NATS_SOURCE=node-fleet-controller

OPENTOFU_BINARY=tofu
OPENTOFU_EXECUTION_ENABLED=false
OPENTOFU_RUNNER_POOL=preview-only
OPENTOFU_DEFAULT_STACK_ROOT=infra/terraform/live
OPENTOFU_PLAN_TIMEOUT_SECONDS=900

OPENBAO_ENABLED=false
OPENBAO_ADDRESS=https://127.0.0.1:8200
OPENBAO_PLATFORM_NAMESPACE=platform
OPENBAO_BOOTSTRAP_AUTH_MOUNT=auth/approle-bootstrap
OPENBAO_FLEET_CERT_AUTH_MOUNT=auth/cert-fleet
OPENBAO_BOOTSTRAP_ROLE=bootstrap-fleet-node-enrollment
OPENBAO_FLEET_CERT_ROLE=fleet-node-enrolled
OPENBAO_RESPONSE_WRAP_TTL=15m
