# ── CyberVPN Telegram Bot — Environment Configuration ─────────────────

# ── Bot Core ─────────────────────────────────────────────────────────────
BOT_TOKEN=replace-with-staging-bot-token
BOT_USERNAME=CyberVPNStageBot
TELEGRAM_BOT_STAGING_USERNAME=CyberVPNStageBot
TELEGRAM_BOT_PRODUCTION_USERNAME=CyberVPNBot
BOT_MODE=polling                    # polling | webhook
TELEGRAM_BOT_MENU_BUTTON=commands   # commands | miniapp | default
TELEGRAM_MINIAPP_URL=https://cyber-vpn.net/ru-RU/miniapp
ENVIRONMENT=development             # development | staging | production
SENTRY_DSN=
SENTRY_RELEASE=
TELEGRAM_BOT_SKIP_NETWORK_CALLS=false
TELEGRAM_BOT_OBSERVABILITY_INTERNAL_SECRET=

# ── Telegram Anti-Spam / Rate Limiting ─────────────────────────────────
TELEGRAM_THROTTLE_ENABLED=true
TELEGRAM_THROTTLE_FAIL_OPEN=false
TELEGRAM_MESSAGE_RATE_WINDOW_SECONDS=10
TELEGRAM_MESSAGE_RATE_MAX_REQUESTS=5
TELEGRAM_CALLBACK_RATE_WINDOW_SECONDS=3
TELEGRAM_CALLBACK_RATE_MAX_REQUESTS=3

# ── Webhook (required when BOT_MODE=webhook) ─────────────────────────────
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_PATH=/webhook/telegram
WEBHOOK_PORT=8080
WEBHOOK_SECRET_TOKEN=your-secret-token-here

# ── Backend API ──────────────────────────────────────────────────────────
BACKEND_API_URL=http://localhost:8000/api/v1
BACKEND_API_KEY=your-backend-api-key
BACKEND_TIMEOUT=30
BACKEND_MAX_RETRIES=3
BACKEND_RETRY_BACKOFF=0.5
AUTH_BACKEND_API_URL=http://localhost:8000/api/v1
AUTH_BACKEND_INTERNAL_SECRET=replace-with-backend-telegram-bot-internal-secret

# ── Redis / Valkey ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_DB=1
REDIS_PASSWORD=
REDIS_KEY_PREFIX=cybervpn:bot:
REDIS_TTL_SECONDS=3600

# ── Payment: Crypto Bot ──────────────────────────────────────────────────
CRYPTOBOT_ENABLED=true
CRYPTOBOT_TOKEN=your-cryptobot-token
CRYPTOBOT_NETWORK=mainnet            # mainnet | testnet

# ── Payment: YooKassa ────────────────────────────────────────────────────
YOOKASSA_ENABLED=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_TEST_MODE=false

# ── Payment: Telegram Stars ──────────────────────────────────────────────
TELEGRAM_STARS_ENABLED=true

# ── Trial ────────────────────────────────────────────────────────────────
TRIAL_ENABLED=true
TRIAL_DAYS=2
TRIAL_TRAFFIC_GB=2

# ── Referral ─────────────────────────────────────────────────────────────
REFERRAL_ENABLED=true
REFERRAL_BONUS_DAYS=3
REFERRAL_MAX_REFERRALS=100

# ── Admin ────────────────────────────────────────────────────────────────
ADMIN_IDS=123456789,987654321       # Comma-separated Telegram IDs
SUPPORT_USERNAME=CyberVPNSupport

# ── i18n ─────────────────────────────────────────────────────────────────
DEFAULT_LANGUAGE=ru
AVAILABLE_LANGUAGES=ru,en

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_JSON_FORMAT=true
LOG_SHOW_LOCALS=false

# ── Prometheus ───────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_PATH=/metrics
